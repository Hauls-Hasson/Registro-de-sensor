#include <SPI.h>
#include <USBHost.h>
#include <FileSystem.h>

USBHost usb;
FileSystem fs;

const int sensorPin = A0;
const float threshold = 500.0;

enum SensorState {
  BELOW,
  ABOVE
};

SensorState currentState = BELOW;

unsigned long startMillis = 0;
unsigned long activationStart = 0;

File logFile;

void setup() {
  Serial.begin(115200);
  pinMode(sensorPin, INPUT);

  usb.begin();

  if (!fs.begin()) {
    Serial.println("USB filesystem failed!");
    while (1);
  }

  logFile = fs.open("log.txt", FILE_WRITE);
  if (!logFile) {
    Serial.println("Error opening file!");
    while (1);
  }

  activationStart = millis();

  logFile.println("=== SYSTEM START ===");
  logFile.flush();
}

void loop() {
  usb.Task();

  unsigned long now = millis();
  float sensorValue = analogRead(sensorPin);

  unsigned long elapsed = now - activationStart;

  unsigned long totalSeconds = elapsed / 1000;
  unsigned long ms = elapsed % 1000;
  unsigned long seconds = totalSeconds % 60;
  unsigned long minutes = (totalSeconds / 60) % 60;
  unsigned long hours = (totalSeconds / 3600) % 24;
  unsigned long days = totalSeconds / 86400;

  // STATE MACHINE
  switch (currentState) {

    case BELOW:
      if (sensorValue > threshold) {
        currentState = ABOVE;
        startMillis = now;

        logFile.print("START | Day ");
        logFile.print(days);
        logFile.print(" | ");
        printTime(logFile, hours, minutes, seconds, ms);
        logFile.println();
        logFile.flush();
      }
      break;

    case ABOVE:
      if (sensorValue <= threshold) {
        currentState = BELOW;

        unsigned long duration = now - startMillis;

        unsigned long d_ms = duration % 1000;
        unsigned long d_sec = (duration / 1000) % 60;
        unsigned long d_min = (duration / 60000) % 60;
        unsigned long d_hr = duration / 3600000;

        logFile.print("STOP  | Day ");
        logFile.print(days);
        logFile.print(" | ");
        printTime(logFile, hours, minutes, seconds, ms);

        logFile.print(" | Duration: ");
        logFile.print(d_hr); logFile.print("h ");
        logFile.print(d_min); logFile.print("m ");
        logFile.print(d_sec); logFile.print("s ");
        logFile.print(d_ms); logFile.print("ms");

        logFile.println();
        logFile.flush();
      }
      break;
  }
}

void printTime(File &file, unsigned long h, unsigned long m, unsigned long s, unsigned long ms) {
  if (h < 10) file.print("0");
  file.print(h); file.print(":");

  if (m < 10) file.print("0");
  file.print(m); file.print(":");

  if (s < 10) file.print("0");
  file.print(s); file.print(".");

  if (ms < 100) file.print("0");
  if (ms < 10) file.print("0");
  file.print(ms);
}
